# ─────────────────────────────────────────────────────────────────────────────
#  .env.example
#  Copia este archivo como .env y rellena los valores reales.
#  El archivo .env NO debe subirse a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Proyecto ─────────────────────────────────────────────────────────────────
PROJECT_NAME="{{ project_name }}"
ML_TYPE="{{ ml_type }}"

# ── Rutas personalizadas (opcional) ──────────────────────────────────────────
# Por defecto el proyecto usa rutas relativas al directorio raíz.
# Descomenta y ajusta si quieres sobreescribirlas.
# DATA_DIR="/ruta/absoluta/a/data"
# MODELS_DIR="/ruta/absoluta/a/models"
# REPORTS_DIR="/ruta/absoluta/a/reports"

# ── Base de datos / almacenamiento externo (si aplica) ───────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mi_base_de_datos
# DB_USER=usuario
# DB_PASSWORD=contraseña_secreta

# ── APIs externas ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# KAGGLE_USERNAME=tu_usuario
# KAGGLE_KEY=tu_clave_kaggle

# ── MLflow / experimentos (opcional) ─────────────────────────────────────────
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME={{ project_slug }}

{% if ml_type == "redes_neuronales" %}
# ── PyTorch / GPU ─────────────────────────────────────────────────────────────
# Fuerza CPU aunque haya GPU disponible (útil para debug):
# CUDA_VISIBLE_DEVICES=""
# Activa TF32 para operaciones matriciales en GPUs Ampere+:
# TORCH_ALLOW_TF32=1
{% endif %}

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
